{
  "name": "ai-testgen",
  "version": "1.0.0",
  "description": "AI-powered test case generator from PRDs, OpenAPI specs, and user stories",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "ai-testgen": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --check \"**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "ai",
    "test",
    "generator",
    "playwright",
    "gherkin",
    "openapi",
    "llm",
    "automation",
    "testing"
  ],
  "author": "Quvantic <info@quvantic.com> (https://quvantic.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mustafaautomation/ai-testgen.git"
  },
  "homepage": "https://github.com/mustafaautomation/ai-testgen#readme",
  "bugs": {
    "url": "https://github.com/mustafaautomation/ai-testgen/issues"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ]
}
